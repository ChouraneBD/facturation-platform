# MongoDB (clients, factures, users)
MONGODB_URI=mongodb://127.0.0.1:27017/facturation

# JSON Server (articles, categories, parametres)
JSON_SERVER_URL=http://localhost:3001
JSON_SERVER_PORT=3001

JWT_SECRET=change_me_in_production

# Firebase Realtime Database (workflow alerts)
